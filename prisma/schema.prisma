// CloudStream Web — Prisma schema
// Uses SQLite with a relative file path so no DATABASE_URL env var is needed.
// The db file is created at prisma/dev.db (or db/custom.db if you set DATABASE_URL).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}
